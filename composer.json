{
	"name": "xml-sitemap-engines/xml-sitemap-engines-advanced",
	"description": "Premium add-on for XML Sitemap Engines — GSC + Bing + Yandex + Baidu + category blacklist + 1,000-URL split + bulk editor.",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"homepage": "https://wordpress.org/plugins/xml-sitemap-engines/",
	"require": {
		"php": ">=7.4",
		"composer/installers": "^2.0"
	},
	"require-dev": {
		"phpunit/phpunit": "^9.6",
		"brain/monkey": "^2.6",
		"wp-coding-standards/wpcs": "^3.0",
		"phpcompatibility/phpcompatibility-wp": "^2.1",
		"yoast/phpunit-polyfills": "^2.0",
		"squizlabs/php_codesniffer": "^3.7",
		"dealerdirect/phpcodesniffer-composer-installer": "^1.0"
	},
	"config": {
		"allow-plugins": {
			"composer/installers": true,
			"dealerdirect/phpcodesniffer-composer-installer": true
		},
		"sort-packages": true
	},
	"scripts": {
		"test": "phpunit --testsuite unit",
		"lint": "phpcs --standard=phpcs.xml.dist",
		"lint:fix": "phpcbf --standard=phpcs.xml.dist"
	}
}
